# Server Configuration
HOST=0.0.0.0
PORT=8863
# CORS origins - include all frontend ports and remote domains
# Development: http://localhost:5173
# Local production: http://localhost:8864
# Remote access (FRP): https://your-domain.com:port
CORS_ORIGINS=http://localhost:5173,http://localhost:8863,http://localhost:8864,http://localhost:8863,https://frp-oil.com:22346

# Authentication
VIBE2CRAZY_PASSWORD=your-secure-password-here
SESSION_EXPIRE_HOURS=24
SECRET_KEY=change-this-to-a-random-secret-key

# Storage
PROJECTS_DIR=./projects
DATABASE_URL=sqlite:///./data/vibe2crazy.db

# Git
GIT_DEFAULT_BRANCH=main

# Tmux
TMUX_SESSION_PREFIX=vibe2crazy-

# Update check settings
UPDATE_SERVER_URL=https://your-server.com
CURRENT_VERSION=1.0.0
