# Production mode API configuration
# Leave empty to use dynamic URL construction based on window.location
# This supports both local access (localhost:8864) and remote access (domain:port)
#
# Scenario 1: Backend is proxied through same origin as frontend (e.g., via FRP or nginx)
# Frontend: https://frp-oil.com:22346 → Backend: https://frp-oil.com:22346/api
# Leave both variables empty:
VITE_API_BASE=
VITE_WS_BASE=
#
# Scenario 2: Backend is on separate port
# Frontend: https://frp-oil.com:22346 → Backend: https://frp-oil.com:22347/api
# Uncomment and set:
# VITE_API_BASE=https://frp-oil.com:22347/api
# VITE_WS_BASE=wss://frp-oil.com:22347/ws

